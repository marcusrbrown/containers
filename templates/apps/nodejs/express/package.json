{
  {% set pinned_dependency_versions = {
    "helmet": "7.1.0",
    "cors": "2.8.5",
    "compression": "1.7.4",
    "morgan": "1.10.0"
  } %}
  {% set pinned_dev_dependency_versions = {
    "nodemon": "3.0.0",
    "@types/node": "20.17.24",
    "@types/express": "4.17.17"
  } %}
  {#
    Resolve dependency entries in three ways:
    1) Scoped package with version: @scope/pkg@x.y.z
    2) Non-scoped package with version: pkg@x.y.z
    3) Unversioned package found in pinned_versions defaults.
    If no pinned version is found, emit an explicit template error sentinel value.
  #}
  {% macro resolve_package_version(package, pinned_versions) -%}
  {% if package.startswith('@') and package.count('@') > 1 -%}
  "{{ package.rsplit('@', 1)[0] }}": "{{ package.rsplit('@', 1)[1] }}"
  {% elif not package.startswith('@') and '@' in package -%}
  "{{ package.split('@', 1)[0] }}": "{{ package.split('@', 1)[1] }}"
  {% elif package in pinned_versions -%}
  "{{ package }}": "{{ pinned_versions[package] }}"
  {% else -%}
  "{{ package }}": "TEMPLATE-ERROR-UNPINNED-DEPENDENCY"
  {% endif -%}
  {%- endmacro %}
  "name": "{{ app_name }}",
  "version": "1.0.0",
  "description": "{{ description | default('Express.js application generated from template') }}",
  "main": "{% if enable_typescript %}dist/app.js{% else %}src/app.js{% endif %}",
  "scripts": {
    {% if enable_typescript -%}
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "{% if enable_hot_reload %}nodemon{% else %}npm run build && npm start{% endif %}",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config=jest-e2e.json",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
    {% else -%}
    "start": "node src/app.js",
    "dev": "{% if enable_hot_reload %}nodemon src/app.js{% else %}npm start{% endif %}",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix"
    {% endif %}
  },
  "keywords": [
    "express",
    "nodejs",
    {% if enable_typescript %}"typescript",{% endif %}
    "api",
    "web"
  ],
  "author": "{{ author | default('Container Template Engine') }}",
  "license": "{{ license | default('MIT') }}",
  "dependencies": {
    "express": "4.22.1",
    {% for package in install_packages -%}
    {{ resolve_package_version(package, pinned_dependency_versions) }}{% if not loop.last %},{% endif %}
    {% endfor %}
  },
  "devDependencies": {
    {% if enable_typescript -%}
    "typescript": "5.7.3",
    "@types/express": "4.17.17",
    {% endif -%}
    {% if enable_hot_reload -%}
    "nodemon": "3.0.0",
    {% endif -%}
    "jest": "29.7.0",
    "supertest": "6.3.3",
    "eslint": "8.42.0",
    {% for package in dev_packages -%}
    {{ resolve_package_version(package, pinned_dev_dependency_versions) }}{% if not loop.last %},{% endif %}
    {% endfor %}
  },
  "engines": {
    "node": ">={{ node_version }}.0.0",
    "npm": ">=8.0.0"
  },
  "jest": {
    {% if enable_typescript -%}
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"]
    {% else -%}
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.js", "**/?(*.)+(spec|test).js"]
    {% endif %}
  }
}
